rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read/write to leads collection (for quick-lead popup)
    match /leads/{document} {
      allow read, write: if true;
    }

    // Allow anyone to read/write to contact_messages collection (for contact form)
    match /contact_messages/{document} {
      allow read, write: if true;
    }

    // Allow anyone to read/write to career_applications collection
    match /career_applications/{document} {
      allow read, write: if true;
    }

    // Allow anyone to read career collection (for job listings)
    match /careers/{document} {
      allow read: if true;
    }

    // Allow authenticated users to read/write other collections
    match /{document=**} {
      allow read, write: if true;
    }
  }
}